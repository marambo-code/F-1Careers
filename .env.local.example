# ─── Supabase ─────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (Claude) ───────────────────────────────────────────
# Get this from: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe ───────────────────────────────────────────────────────
# Get these from: dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe Product Price IDs ─────────────────────────────────────
# Create these in Stripe dashboard → Products
# Career Strategy Engine — set price to $300 (or your chosen price)
STRIPE_STRATEGY_PRICE_ID=price_...
# RFE Analyzer — set price to $200
STRIPE_RFE_PRICE_ID=price_...

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Precedent Engine feature flags (both OFF by default) ─────────
# PRECEDENT_GROUNDING=on appends a short, honestly-framed AAO corpus block to
# the Strategy Report and RFE Analyzer prompts. Off/unset = prompts are
# byte-identical to the ungrounded prompts; any grounding failure or timeout
# also falls back to the ungrounded prompt. Paid generation never depends on it.
# PRECEDENT_GROUNDING=on

# PRECEDENT_ENGINE_PUBLIC=on exposes the read-only /precedent-engine page
# (aggregate stats only) without login. Off/unset = login required (default).
# PRECEDENT_ENGINE_PUBLIC=on
